# Resend — transactional email for the contact form
# 1. Sign up at https://resend.com (free tier covers 3,000 emails/month)
# 2. Create an API key in the Resend dashboard
# 3. Verify your sending domain (or use the resend.dev sandbox while testing)
# 4. Copy this file to .env.local and fill in real values
# 5. Restart `next dev` after changing env vars

RESEND_API_KEY=re_your_resend_api_key_here

# Where contact-form submissions are delivered
CONTACT_TO_EMAIL=heidi@2gogtravel.com

# The "From" address — must be on a domain you have verified in Resend.
# Default uses Resend's sandbox domain so it works out of the box; once
# you have verified 2girlsonthego.com (or another domain) in Resend,
# override this with e.g. "2 Girls on the Go <noreply@2girlsonthego.com>"
CONTACT_FROM_EMAIL=2 Girls on the Go <onboarding@resend.dev>
